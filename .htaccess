# Canonicalize: apex -> www, HTTP -> HTTPS
RewriteEngine On

# 1. Send bare apex straight to https://www so visitors who type
#    "designwithjazz.com" never see a cert error (since the cert
#    only covers www.). This must come before the HTTP->HTTPS rule.
RewriteCond %{HTTP_HOST} ^designwithjazz\.com$ [NC]
RewriteRule ^(.*)$ https://www.designwithjazz.com/$1 [L,R=301]

# 2. Force HTTPS for everything else (i.e., http://www -> https://www)
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 3. Far-future cache for static assets that change rarely or are
#    cache-busted via ?v=token (deploy.sh stamps a fresh token from
#    the git short SHA into index.html on every deploy).
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"

    ExpiresByType image/webp                "access plus 1 year"
    ExpiresByType image/png                 "access plus 1 year"
    ExpiresByType image/jpeg                "access plus 1 year"
    ExpiresByType image/svg+xml             "access plus 1 year"
    ExpiresByType image/x-icon              "access plus 1 year"
    ExpiresByType font/otf                  "access plus 1 year"
    ExpiresByType font/woff                 "access plus 1 year"
    ExpiresByType font/woff2                "access plus 1 year"
    ExpiresByType application/font-woff     "access plus 1 year"
    ExpiresByType application/font-woff2    "access plus 1 year"

    # CSS/JS get the same long cache because their URLs change on every
    # deploy via ?v=<sha>. The OLD ?v= URL stays cached forever harmlessly;
    # the new HTML always points at the new ?v= URL.
    ExpiresByType text/css                  "access plus 1 year"
    ExpiresByType application/javascript    "access plus 1 year"
</IfModule>

# 4. HTML must always re-validate so visitors get the latest ?v= tokens
#    (which then trigger fresh CSS/JS loads). Browsers still get a cached
#    copy when the server returns 304 Not Modified, so this is fast - it
#    just guarantees you'll never see a stale page after a deploy.
<FilesMatch "\.(html|htm)$">
    Header always set Cache-Control "no-cache, must-revalidate, max-age=0"
    Header always set Pragma "no-cache"
    Header always set Expires "0"
</FilesMatch>
<FilesMatch "^index\.html$">
    Header always set Cache-Control "no-cache, must-revalidate, max-age=0"
</FilesMatch>

# 5. Static assets get 1-year immutable cache. LiteSpeed's default
#    cache-control of 7 days isn't long enough for Lighthouse - "Header
#    always" overrides it. immutable tells the browser the file at this
#    URL will never change (which is true: deploy.sh stamps a fresh
#    ?v=<sha> token onto styles.css/main.js refs every deploy, so cache
#    busts via URL change).
<FilesMatch "\.(webp|png|jpg|jpeg|gif|svg|ico|woff|woff2|otf|ttf|css|js)$">
    Header always set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# 5. Gzip/deflate text-based responses on the wire.
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/xml text/plain
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE application/xml application/rss+xml
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>
