# Canonicalize: apex -> www, HTTP -> HTTPS
RewriteEngine On

# 1. Send bare apex straight to https://www so visitors who type
#    "designwithjazz.com" never see a cert error (since the cert
#    only covers www.). This must come before the HTTP->HTTPS rule.
RewriteCond %{HTTP_HOST} ^designwithjazz\.com$ [NC]
RewriteRule ^(.*)$ https://www.designwithjazz.com/$1 [L,R=301]

# 2. Force HTTPS for everything else (i.e., http://www -> https://www)
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 3. Far-future cache for static assets, short cache for the HTML so
#    content updates show up without users hard-refreshing.
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"

    # Long cache: assets that change rarely or get cache-busted via ?v=
    ExpiresByType image/webp                "access plus 1 year"
    ExpiresByType image/png                 "access plus 1 year"
    ExpiresByType image/jpeg                "access plus 1 year"
    ExpiresByType image/svg+xml             "access plus 1 year"
    ExpiresByType image/x-icon              "access plus 1 year"
    ExpiresByType font/otf                  "access plus 1 year"
    ExpiresByType font/woff                 "access plus 1 year"
    ExpiresByType font/woff2                "access plus 1 year"
    ExpiresByType application/font-woff     "access plus 1 year"
    ExpiresByType application/font-woff2    "access plus 1 year"

    # Short cache: HTML so copy edits propagate fast
    ExpiresByType text/html                 "access plus 5 minutes"

    # Medium cache: CSS/JS (files use ?v= cache-busters in HTML)
    ExpiresByType text/css                  "access plus 1 month"
    ExpiresByType application/javascript    "access plus 1 month"
</IfModule>

# 4. Gzip/deflate text-based responses on the wire.
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/xml text/plain
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE application/xml application/rss+xml
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>
